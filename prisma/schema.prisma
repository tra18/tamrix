generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique @db.VarChar(320)
  name         String         @db.VarChar(200)
  passwordHash String         @db.VarChar(200)
  totpSecret   String?        @db.VarChar(100)
  mfaEnabled   Boolean        @default(false)
  active       Boolean        @default(true)
  role         AdminRole      @default(ADMIN)
  createdAt    DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(6)
  sessions     AdminSession[]

  @@map("admin_users")
}

model AdminSession {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  ip        String?   @db.VarChar(64)
  userAgent String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model QuoteRequest {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)
  status          RequestStatus @default(NEW)
  adminNotes      String?       @db.Text
  locale          String        @db.VarChar(5)
  company         String        @db.VarChar(200)
  contactName     String        @db.VarChar(200)
  email           String        @db.VarChar(320)
  phone           String?       @db.VarChar(30)
  projectSlugs    String[]
  customProject   Boolean       @default(false)
  sector          String        @db.VarChar(50)
  companySize     String        @db.VarChar(20)
  description     String        @db.Text
  modules         String[]
  userCount       String        @db.VarChar(20)
  integrations    String[]
  needsMobile     Boolean       @default(false)
  needsMultiSite  Boolean       @default(false)
  existingSystems String?       @db.Text
  timeline        String        @db.VarChar(20)
  complexity      String        @db.VarChar(20)
  specification   Json

  @@index([createdAt])
  @@index([status])
  @@index([email])
  @@map("quote_requests")
}

model OrderRequest {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  status      RequestStatus @default(NEW)
  adminNotes  String?       @db.Text
  locale      String        @db.VarChar(5)
  appSlug     String        @db.VarChar(80)
  appName     String        @db.VarChar(200)
  company     String        @db.VarChar(200)
  contactName String        @db.VarChar(200)
  email       String        @db.VarChar(320)
  phone       String?       @db.VarChar(30)
  plan        String        @db.VarChar(20)
  notes       String?       @db.Text

  @@index([createdAt])
  @@index([status])
  @@index([email])
  @@index([appSlug])
  @@map("order_requests")
}
