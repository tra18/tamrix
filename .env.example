# PostgreSQL — ne jamais committer le fichier .env réel
#
# Local (Docker) :
#   docker compose up -d
#   DATABASE_URL="postgresql://tamrix:tamrix_dev_change_me@localhost:5432/tamrix?schema=public"
#
# Production (ajoutez sslmode=require) :
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tamrix?schema=public&sslmode=require"

DATABASE_URL="postgresql://tamrix:tamrix_dev_change_me@localhost:5432/tamrix?schema=public"

# Panneau admin — générez des valeurs longues et aléatoires
# Exemple : openssl rand -base64 32
ADMIN_PASSWORD="changez-moi-mot-de-passe-tres-long"
ADMIN_SECRET="changez-moi-secret-hmac-tres-long"

# Notifications e-mail (Resend — https://resend.com)
# Admin : alerte à chaque devis / commande
# Client : e-mail de confirmation automatique (même config)
ADMIN_NOTIFICATION_EMAIL="vous@example.com"
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Tamrix <notifications@votredomaine.com>"
APP_URL="http://localhost:3000"

# Rate limiting production (optionnel — sinon mémoire locale)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."
